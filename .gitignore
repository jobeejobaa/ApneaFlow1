# ============================================================
# .gitignore — Apnea Flow
# ============================================================

# Dépendances — jamais dans git, régénérées avec npm install
node_modules/

# Build React (généré par npm run build)
frontend/dist/

# Variables d'environnement — contiennent des secrets !
.env
.env.local
.env.*.local

# Uploads utilisateurs (photos de profil)
backend/uploads/

# Logs
*.log
npm-debug.log*

# Éditeurs & OS
.DS_Store
Thumbs.db
.vscode/
.idea/
