# Copie ce fichier en .env et remplis tes valeurs

# Base de données PostgreSQL
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:motdepasse@localhost:5432/apnea_flow"

# Secret JWT — change cette valeur par quelque chose de long et aléatoire
JWT_SECRET="change-moi-par-une-longue-chaine-aleatoire-super-secrete"

# Port du serveur
PORT=3001
