// ============================================================
// SCHÉMA PRISMA — Apnea Flow
// C'est ici qu'on définit la structure de notre base de données.
// Prisma va générer les tables PostgreSQL à partir de ces modèles.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- ENUMS ----
// Un enum = une liste de valeurs autorisées (comme un menu déroulant)

enum Role {
  ELEVE
  INSTRUCTEUR
}

enum CourseName {
  INITIATION
  AIDA1
  AIDA2
  AIDA3
  AIDA4
  AIDA_INSTRUCTEUR
}

enum Location {
  PISCINE
  MER
  BLUE_HOLE
}

enum CourseType {
  STATIQUE
  DYNAMIQUE_PALMES_OU_SANS_PALMES
  PROFONDEUR_PALMES_OU_SANS_PALMES
  IMMERSION_LIBRE
  POIDS_VARIABLE
  NO_LIMITS
}

enum RequestStatus {
  PENDING   // En attente de réponse
  ACCEPTED  // Acceptée par l'instructeur
  REFUSED   // Refusée par l'instructeur
}

// ---- MODÈLES ----
// Chaque modèle = une table dans PostgreSQL

model User {
  id        String   @id @default(uuid())   // Clé primaire UUID auto-générée
  name      String
  email     String   @unique                // Email unique (pas deux fois le même)
  password  String                          // Hash bcrypt (JAMAIS le mot de passe en clair !)
  role      Role     @default(ELEVE)
  bio       String?                         // Le ? signifie optionnel (nullable)
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt             // Mis à jour automatiquement par Prisma

  // Relations
  coursesCreated   Course[]         // Un instructeur peut créer plusieurs cours
  enrollments      Enrollment[]     // Un élève peut avoir plusieurs inscriptions
  sentRequests     CourseRequest[]  @relation("StudentRequests")     // Demandes envoyées (élève)
  receivedRequests CourseRequest[]  @relation("InstructorRequests")  // Demandes reçues (instructeur)

  @@map("users") // Nom de la table en base (convention : snake_case pluriel)
}

model Course {
  id            String     @id @default(uuid())
  title         CourseName                     // Niveau du cours (AIDA1, AIDA2, etc.)
  descriptionFr String?                        // Description en français
  descriptionEn String?                        // Description en anglais
  sessions    Json                           // [{ date: "YYYY-MM-DD", time: "HH:MM" }] — au moins 1
  location    Location
  types       CourseType[]                   // Un ou plusieurs types de pratique
  capacity    Int        @default(4)         // Max 4 élèves par cours (1 à 4)
  createdById String                         // Clé étrangère vers User

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@map("courses")
}

model Enrollment {
  id            String  @id @default(uuid())
  userId        String
  courseId      String
  withEquipment Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Contrainte : un élève ne peut s'inscrire qu'une fois par cours
  @@unique([userId, courseId])
  @@map("enrollments")
}

// ---- DEMANDES DE COURS PRIVÉES ----
// Un élève demande un cours personnalisé à un instructeur
model CourseRequest {
  id           String        @id @default(uuid())
  studentId    String
  instructorId String
  title        CourseName    // Niveau souhaité (AIDA1, AIDA2, etc.)
  location     Location      // Lieu souhaité
  date         String        // Date souhaitée (YYYY-MM-DD)
  time         String        // Heure souhaitée (HH:MM)
  message      String?       // Message libre optionnel
  status       RequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  student    User @relation("StudentRequests",    fields: [studentId],    references: [id], onDelete: Cascade)
  instructor User @relation("InstructorRequests", fields: [instructorId], references: [id], onDelete: Cascade)

  @@map("course_requests")
}
